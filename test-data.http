### REST Client for AI-Game-Project-1
### Test data creation for Docker environment
### Install "REST Client" extension in VS Code to use this file

@baseUrl = http://localhost:5000/api
@contentType = application/json

###
### 1. Check API Health
GET {{baseUrl}}/enemies
Content-Type: {{contentType}}

###
### 2. Create Goblin Enemy
POST {{baseUrl}}/enemies
Content-Type: {{contentType}}

{
  "name": "Goblin",
  "description": "A small green creature with big ears. Common in forests and caves.",
  "health": 10,
  "attack": 5,
  "defense": 2,
  "experience": 25,
  "drops": [
    {
      "itemName": "Gold",
      "dropRate": 0.8,
      "quantity": 5
    },
    {
      "itemName": "Goblin Dagger",
      "dropRate": 0.3,
      "quantity": 1
    }
  ]
}

